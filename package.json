{
  "name": "@chataigram/web",
  "version": "0.0.1",
  "private": true,
  "description": "ChatAigram frontend — pages, components, routing, interactions.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/init-submodule.mjs",
    "dev": "vite",
    "dev:mocks": "VITE_USE_MOCKS=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "mocks:init": "msw init public/ --save",
    "core:bump": "node scripts/bump-core.mjs",
    "core:status": "git -C packages/core status && echo --- && git -C packages/core log -1 --oneline"
  },
  "dependencies": {
    "@chataigram/core": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "lottie-react": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^25.0.1",
    "msw": "^2.4.9",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
