# scripts/generate-fake-avatars.mjs 的本地配置。
#
# 用法：
#   1. cp .env.fake-avatars.example .env.fake-avatars.local
#   2. 把下面 4 个值改成你自己的（USER_ID/BEARER 不要 commit）
#   3. pnpm gen:fake-avatars
#
# .env.fake-avatars.local 已被 .gitignore 排除，不会进仓。

# 后端地址（必填）。生产填 https://chataigram.com/api ；本地 dev 填 http://localhost:8000/api
API_BASE=http://localhost:8000/api

# 你的 user_id（必填）。脚本会用它发起 generate / update_avatar 请求
USER_ID=

# 鉴权（按后端实际要求二选一；都不要就留空）
# Bearer token：
BEARER=
# 或者整段 header（例如 cookie）：AUTH_HEADER='Cookie: session=xxxxxxxx'
AUTH_HEADER=

# 可选：只跑指定几个（逗号分隔，对应 lottie/ 文件名前缀）
# ONLY=cyberpunk-m,witch-f

# 可选：DRY=1 走通流程但不写盘，建议第一次先 dry 验证
# DRY=1
