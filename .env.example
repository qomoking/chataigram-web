# 复制为 .env.local 后修改（.env.local 不入版本库）。

# ────────────────────────────────────────────────────────────
#  MSW mock 开关
# ────────────────────────────────────────────────────────────
# true  → 启动 MSW，/api/* 全部走 src/mocks/handlers.ts
# false → 直连真后端（默认，vite 代理 localhost:8000）
#
# 命令行快捷方式：pnpm dev:mocks（已在 package.json scripts 里）
VITE_USE_MOCKS=false

# ────────────────────────────────────────────────────────────
#  后端地址（可选）
# ────────────────────────────────────────────────────────────
# 默认让 Vite dev server 代理 /api → localhost:8000
# 部署时由运维/CDN 决定，这里不用改
# VITE_API_BASE_URL=/api
